{
  "name": "bug-hunter",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-driven bug hunter agent for local SPA scanning",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "scan": "node scripts/check-node.mjs && tsx src/index.ts",
    "scan:shipment": "node scripts/check-node.mjs && tsx src/index.ts -- --config configs/shipment.json",
    "pilot": "node scripts/check-node.mjs && tsx src/pilot.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "playwright": "^1.54.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
